function enable_starship_prompt(){
    # Install starship if not installed (v1.23)
    if [ ! -s /usr/local/bin/starship ]; then

        wget https://github.com/starship/starship/releases/download/v1.23.0/starship-x86_64-unknown-linux-gnu.tar.gz
        tar -xvf starship-x86_64-unknown-linux-gnu.tar.gz
        sudo mv starship /usr/local/bin/starship
        rm -f starship-x86_64-unknown-linux-gnu.tar.gz

    fi

    if [ ! -d ~/.config ]; then
        mkdir -p ~/.config
    fi

    # Create config file
    if [ ! -s ~/.config/starship.toml ]; then
        touch ~/.config/starship.toml 2 >&1 /dev/null
    fi

    # Install catppuccin-powerline mocha preset
    if [[ ! -s ~/.config/starship.toml ]]; then
        # starship preset tokyo-night -o ~/.config/starship.toml
        starship preset catppuccin-powerline -o ~/.config/starship.toml
    fi

    # May need to add more here later to enable a transient prompt

    # Run Starship
    eval "$(starship init zsh)"
}

