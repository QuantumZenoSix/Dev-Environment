function enable_ohmyposh(){

    if [[ ! -s $HOME/bin/oh-my-posh ]]; then


        [ -d "$HOME/bin" ] || mkdir -p "$HOME/bin"

        if ! command -v unzip >/dev/null 2>&1; then
            sudo apt install unzip -y
        fi

        curl -s https://ohmyposh.dev/install.sh | bash -s -- -d $HOME/bin
        [[ ":$PATH:" == *":$HOME/bin:"* ]] || PATH="$PATH:$HOME/bin"
    fi

    # posh_theme='https://github.com/JanDeDobbeleer/oh-my-posh/blob/main/themes/night-owl.omp.json'
    posh_theme='https://github.com/JanDeDobbeleer/oh-my-posh/blob/main/themes/tokyonight_storm.omp.json'
    eval "$(oh-my-posh init zsh --config $posh_theme)"

}



