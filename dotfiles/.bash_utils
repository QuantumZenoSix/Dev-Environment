docker_force_old_version(){
    export DOCKER_API_VERSION=1.43
}

# Spin up quick ubuntu container
dockbuntu(){
    # force non-newest docker version as api doesn't support past 1.43 as of 3/26
    # docker_force_old_version
    sudo docker run -it --rm ubuntu:24.04 bash -c "apt update && apt install -y sudo wget git curl && DEBIAN_FRONTEND=noninteractive TZ=America/Los_Angeles apt install vim -y && exec bash"
}

dockarch(){
    sudo docker run -it --rm archlinux bash -c "yes | pacman -Syu && yes | pacman -S sudo wget git curl which vim && export EDITOR=vim &&  exec bash"
}

