# Quick Ed25519 SSH key generator with custom comment

# Usage: mksshkey "my name - 2026 lappy"

mksshkey() {

    if [ $# -eq 0 ]; then

        echo "Usage: mksshkey 'your comment here'  [extra ssh-keygen options...]"
        echo "Example:"
        echo "  mksshkey 'bobby@work-laptop' -a 150"
        return 1

    fi

    local comment="$1"
    shift  # remove the comment so remaining args go to ssh-keygen
    ssh-keygen -t ed25519 -C "$comment" "$@"

}
restart_audio(){

    systemctl --user restart wireplumber pipewire pipewire-pulse

}


change_pop_graphics(){

    if [[ "${1}" = "low" ]]; then
        sudo system76-power graphics integrated # iGPU only (best battery, no NVIDIA)
    elif [[ "${1}" = "med" ]]; then
        sudo system76-power graphics hybrid    # default & most battery-friendly

    elif [[ "${1}" = "high" ]]; then
        sudo system76-power graphics nvidia    # max performance (uses more power)
    else
        echo "Options are 'low' | 'med' | 'high'"
    fi

    echo 

    local current=$(system76-power graphics )
    echo "Current: $current"
}


up(){

    # Git to pull down the latest and greatest and update my local dotfiles via nix home-manager
    
    cd ~/.config/home-manager/

    # Add ssh-key to ssh-agent
    ssh_keyupdate

    # Stash anything lingering
    git stash save
    git pull
    git stash apply
    git add -A

    home-manager switch -b backup --flake .#${USER}

}

get_wsl_diskusage(){

    # ncdu must be installed
    sudo ncdu / --exclude /mnt
}
